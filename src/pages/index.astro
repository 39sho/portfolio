---
import avator from "../assets/avator.png";

import Layout from "../layouts/default.astro";
import Avator from "../components/Avator.astro";
import Hero from "../components/Hero.astro";
import Main from "../layouts/Main.astro";
import { getEntry } from "astro:content";
import Header from "../components/Header.astro";
import { parse } from 'comark';
import { ComarkRenderer } from '@comark/react';

const entry = await getEntry("profile", "about");
const tree = await parse((entry as any).body ?? '');
---

<Layout title="39sho.dev" description="39shoのサイト">
	<Hero>
		<Avator img={avator} slot="avator" />
		<span slot="name">39sho(さくしょー)</span>
	</Hero>
	<div class="sticky top-0 my-4 z-50">
		<Header />
	</div>
	<Main>
		<div class="prose prose-table:text-base w-full mx-auto max-w-none">
			<ComarkRenderer tree={tree} className="prose" />
		</div>
	</Main>
</Layout>
